package main

import (
	"fmt"
	"os"
	"time"

	"github.com/AnatoleLucet/loom"
	. "github.com/AnatoleLucet/loom-term/components"
	"github.com/AnatoleLucet/loom-term/internal/animate"
	. "github.com/AnatoleLucet/loom-term/style"
	. "github.com/AnatoleLucet/loom/components"
	. "github.com/AnatoleLucet/loom/signals"
)

func MyApp() loom.Node {
	frame, setFrame := Signal(0)

	go func() {

		for {
			animate.Pace(func(time.Time) {
				setFrame(frame() + 1)
			})
		}
	}()

	return Fragment(
		BindText(func() string {
			f := frame()
			return fmt.Sprintf("Frame: %d", f)
		}),

		Box(
			Apply(Style{
				Width:  "100%",
				Height: 2,

				BackgroundColor: "#f00",
			}),
		),
	)
}

func main() {
	app := NewApp()

	for err := range app.Run(RenderFullscreen, MyApp) {
		fmt.Printf("Error: %v\n", err)
		app.Close()
		os.Exit(1)
	}
}
