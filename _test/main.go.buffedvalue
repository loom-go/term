package main

import (
	"fmt"
	"sync"
	"time"

	"github.com/AnatoleLucet/loom/signals"
)

type RenderContext struct {
	renderMu sync.Mutex

	mu       sync.Mutex
	deffered []func()
}

func (rc *RenderContext) Defer(f func()) {
	rc.mu.Lock()
	defer rc.mu.Unlock()
	rc.deffered = append(rc.deffered, f)
}

func (rc *RenderContext) DrainDeferred() {
	rc.mu.Lock()
	deffered := rc.deffered
	rc.deffered = rc.deffered[:0]
	rc.mu.Unlock()

	for _, f := range deffered {
		f()
	}
}

type BufferedValue[T any] struct {
	ctx *RenderContext

	mu      sync.Mutex
	value   T
	pending []func(T) T
}

func NewBufferedValue[T any](ctx *RenderContext, initial T) *BufferedValue[T] {
	return &BufferedValue[T]{
		ctx:   ctx,
		value: initial,
	}
}

func (s *BufferedValue[T]) Value() T {
	s.mu.Lock()
	defer s.mu.Unlock()
	return s.value
}

func (s *BufferedValue[T]) Set(v T) {
	s.Update(func(T) T {
		return v
	})
}

func (s *BufferedValue[T]) Update(updater func(T) T) {
	s.mu.Lock()
	defer s.mu.Unlock()

	// try to acquire the render lock to perform the update immediately
	if s.ctx.renderMu.TryLock() {
		s.value = updater(s.value)
		s.ctx.renderMu.Unlock()
		renderer.Schedule()
		return
	}

	// else it means we're already rendering, so defer the update to after the current render
	s.ctx.Defer(func() {
		s.value = updater(s.value)
		renderer.Schedule()
	})
}

type Element interface {
	AppendChild(child Element)
	Paint()
}

type BaseElement struct {
	children []Element
}

func (e *BaseElement) AppendChild(child Element) {
	e.children = append(e.children, child)
}

func (e *BaseElement) Paint() {
	e.paintChildren()
}

func (e *BaseElement) paintChildren() {
	for _, child := range e.children {
		child.Paint()
	}
}

type TextElem struct {
	*BaseElement

	content *BufferedValue[string]
}

func NewTextElem(ctx *RenderContext) *TextElem {
	return &TextElem{
		BaseElement: &BaseElement{},
		content:     NewBufferedValue(ctx, ""),
	}
}

func (e *TextElem) SetContent(v string) {
	e.content.Set(v)
}

func (e *TextElem) Paint() {
	fmt.Println("Text:", e.content.Value())

	e.paintChildren()
}

type Renderer struct {
	ctx RenderContext
	mu  sync.Mutex

	scheduled bool

	root *BaseElement
}

func NewRenderer() *Renderer {
	return &Renderer{
		root: &BaseElement{},
	}
}

func (r *Renderer) Root() *BaseElement {
	return r.root
}

func (r *Renderer) Schedule() {
	r.mu.Lock()
	fmt.Println("trying to schedule", r.scheduled)
	if r.scheduled {
		r.mu.Unlock()
		return
	}
	r.scheduled = true
	r.mu.Unlock()

	signals.OnRenderSettled(func() {
		r.ctx.renderMu.Lock()

		for r.scheduled {
			fmt.Println("---- Rendering Frame ----")
			time.Sleep(50 * time.Millisecond)

			r.root.Paint()
			r.scheduled = false

			fmt.Println("running deferred")
			r.ctx.DrainDeferred() // might reschedule an update
			fmt.Println("ran deferred")
		}

		r.ctx.renderMu.Unlock()
	})
}

func Bind(elem *TextElem, val func() string) {
	signals.RenderEffect(func() {
		elem.SetContent(val())
	})
}

var renderer = NewRenderer()

func main() {
	t1 := NewTextElem(&renderer.ctx)
	renderer.Root().AppendChild(t1)
	t2 := NewTextElem(&renderer.ctx)
	renderer.Root().AppendChild(t2)

	val1, setVal1 := signals.Signal("")
	val2, setVal2 := signals.Signal("")

	Bind(t1, val1)
	Bind(t2, val2)

	// Basic test
	setVal1("Hello")
	setVal2("World")

	// Batch test
	signals.Batch(func() {
		setVal1("New Hello")
		setVal2("New World")
	})

	var wg sync.WaitGroup
	wg.Go(func() {
		time.Sleep(10 * time.Millisecond)
		setVal1("Final Hello")
		setVal2("Final World")
	})
	wg.Go(func() {
		setVal1("rendered")
	})

	wg.Wait()
}
