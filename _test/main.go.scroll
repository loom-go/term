package main

import (
	"fmt"
	"os"
	"sync"

	"github.com/AnatoleLucet/loom-term/core"
	"github.com/AnatoleLucet/loom-term/core/types"
	"golang.org/x/term"
)

func main() {
	state, _ := term.MakeRaw(int(os.Stdin.Fd()))
	defer term.Restore(int(os.Stdin.Fd()), state)

	width, height := core.TerminalSize()

	rt, _ := core.NewRuntime(core.RenderFullscreen)
	rt.Root().SetWidth(width)
	rt.Root().SetHeight(height)

	console, _ := core.NewConsoleElement(rt.RenderContext())
	rt.Root().AppendChild(console)

	scrollbox, _ := core.NewScrollBoxElement(rt.RenderContext())
	scrollbox.SetWidth(width)
	scrollbox.SetHeight(20)
	scrollbox.SetBackgroundColor("#00ff0055")
	scrollbox.SetFlexDirection("column")
	rt.Root().AppendChild(scrollbox)

	for i := range 100 {
		log, _ := core.NewTextElement(rt.RenderContext())
		log.SetContent(fmt.Sprintf("Log %d", i))
		scrollbox.AppendChild(log)
	}

	rt.Render()

	var wg sync.WaitGroup
	wg.Add(1)
	go func() {
		defer wg.Done()

		evts, _ := rt.Events()

		for event := range evts {
			switch e := event.(type) {
			case *types.EventKey:
				core.LogDebug(fmt.Sprintf("Key event: %+v", e))

				if e.Ctrl && e.Rune == 'c' {
					rt.Close()
					return
				}
			}
		}
	}()
	wg.Wait()
}
